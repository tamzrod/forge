#!/bin/bash
# KDSE Runtime Command
# Knowledge-Driven Software Engineering

set -e

KDSE_REPO="tamzrod/KDSE"
KDSE_BRANCH="main"
TEMP_DIR=$(mktemp -d)
LOCAL_KDSE_DIR=".kdse"
COMMAND="${1:-}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Protected files that should never be overwritten
PROTECTED_FILES=(
    "context.json"
    "state.json"
)

# Protected directories (user-generated content)
PROTECTED_DIRS=(
    "reports"
)

cleanup() {
    rm -rf "$TEMP_DIR"
}
trap cleanup EXIT

#===============================================================================
# Helper Functions
#===============================================================================

print_header() {
    echo ""
    echo -e "${BLUE}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${BLUE}  $1${NC}"
    echo -e "${BLUE}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
}

print_step() {
    echo -e "${GREEN}[$1]${NC} $2"
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

print_error() {
    echo -e "${RED}✗${NC} $1"
}

is_protected() {
    local file="$1"
    for protected in "${PROTECTED_FILES[@]}"; do
        if [[ "$file" == *"$protected" ]]; then
            return 0
        fi
    done
    return 1
}

is_in_protected_dir() {
    local file="$1"
    for protected_dir in "${PROTECTED_DIRS[@]}"; do
        if [[ "$file" == *"$protected_dir"* ]]; then
            return 0
        fi
    done
    return 1
}

#===============================================================================
# Command: update
#===============================================================================

cmd_update() {
    FILES_ADDED=()
    FILES_UPDATED=()
    FILES_SKIPPED=()

    echo "=== KDSE Update ==="
    echo "Syncing with: https://github.com/$KDSE_REPO"
    echo ""

    # Step 1: Clone latest KDSE repository
    print_step "1/4" "Cloning latest KDSE repository..."
    git clone --depth 1 --branch "$KDSE_BRANCH" "https://github.com/$KDSE_REPO.git" "$TEMP_DIR" 2>/dev/null || {
        echo "ERROR: Failed to clone KDSE repository"
        exit 1
    }

    # Step 2: Compare and sync files
    print_step "2/4" "Comparing files..."
    print_step "3/4" "Synchronizing..."

    REMOTE_KDSE="$TEMP_DIR/.kdse"

    if [ ! -d "$REMOTE_KDSE" ]; then
        echo "ERROR: KDSE runtime not found in remote repository"
        exit 1
    fi

    # Sync files from remote to local
    sync_files() {
        local src_dir="$1"
        local dest_dir="$2"
        
        while IFS= read -r -d '' file; do
            rel_path="${file#$src_dir/}"
            
            if is_protected "$rel_path"; then
                FILES_SKIPPED+=("$rel_path (protected)")
                continue
            fi
            
            if is_in_protected_dir "$rel_path"; then
                FILES_SKIPPED+=("$rel_path (user-generated)")
                continue
            fi
            
            dest_file="$dest_dir/$rel_path"
            dest_file_dir=$(dirname "$dest_file")
            if [ ! -d "$dest_file_dir" ]; then
                mkdir -p "$dest_file_dir"
            fi
            
            if [ -f "$dest_file" ]; then
                if ! diff -q "$file" "$dest_file" > /dev/null 2>&1; then
                    cp "$file" "$dest_file"
                    FILES_UPDATED+=("$rel_path")
                else
                    FILES_SKIPPED+=("$rel_path (identical)")
                fi
            else
                cp "$file" "$dest_file"
                FILES_ADDED+=("$rel_path")
            fi
        done < <(find "$src_dir" -type f -print0)
    }

    if [ ! -d "$LOCAL_KDSE_DIR" ]; then
        mkdir -p "$LOCAL_KDSE_DIR"
    fi

    sync_files "$REMOTE_KDSE" "$LOCAL_KDSE_DIR"

    if [ -d "$TEMP_DIR/docs" ] && [ -d "$TEMP_DIR/docs/kdse" ]; then
        if [ ! -d "docs/kdse" ]; then
            mkdir -p "docs/kdse"
        fi
        sync_files "$TEMP_DIR/docs/kdse" "docs/kdse"
    fi

    print_step "4/4" "Update complete!"
    echo ""
    echo "=== Summary ==="
    echo ""
    echo "Files Added ($(( ${#FILES_ADDED[@]} ))):"
    if [ ${#FILES_ADDED[@]} -eq 0 ]; then
        echo "  None"
    else
        for f in "${FILES_ADDED[@]}"; do
            echo "  + $f"
        done
    fi
    echo ""
    echo "Files Updated ($(( ${#FILES_UPDATED[@]} ))):"
    if [ ${#FILES_UPDATED[@]} -eq 0 ]; then
        echo "  None"
    else
        for f in "${FILES_UPDATED[@]}"; do
            echo "  ~ $f"
        done
    fi
    echo ""
    echo "Files Skipped ($(( ${#FILES_SKIPPED[@]} ))):"
    if [ ${#FILES_SKIPPED[@]} -eq 0 ]; then
        echo "  None"
    else
        for f in "${FILES_SKIPPED[@]}"; do
            echo "  - $f"
        done
    fi
    echo ""
    echo "KDSE runtime synchronized successfully."
}

#===============================================================================
# Command: run
#===============================================================================

cmd_run() {
    print_header "KDSE Session"
    echo "Starting KDSE session for repository: $(basename $(pwd))"
    echo ""
    
    # Phase 0: Initialize
    print_step "1/7" "Initialize - Loading KDSE Runtime..."
    if [ ! -d ".kdse" ]; then
        print_error "KDSE runtime not found. Run 'kdse update' first."
        exit 1
    fi
    print_success "Runtime loaded"
    
    # Phase 1: Verify Standards
    print_step "2/7" "Verify Standards - Checking KDSE methodology..."
    if [ -f ".kdse/knowledge/manifest.yaml" ]; then
        print_success "Knowledge manifest verified"
    fi
    if [ -f ".kdse/bootstrap/commands.yaml" ]; then
        print_success "Command registry verified"
    fi
    
    # Phase 2: Assess Repository
    print_step "3/7" "Assess Repository - Analyzing codebase..."
    assess_repository
    
    # Phase 3: Generate Report
    print_step "4/7" "Generate Report - Creating assessment..."
    generate_report
    
    # Phase 5: Await Approval
    print_step "5/7" "Await Approval - Review recommendations..."
    echo ""
    echo "─────────────────────────────────────────────────────────────"
    echo " TOP RECOMMENDATION"
    echo "─────────────────────────────────────────────────────────────"
    echo ""
    echo " Action: $TOP_RECOMMENDATION"
    echo " Priority: $TOP_PRIORITY"
    echo " Impact: $TOP_IMPACT"
    echo ""
    
    # Phase 6: Implement (placeholder - would be interactive)
    print_step "6/7" "Implement - Execute recommended actions..."
    print_warning "Interactive implementation not yet supported"
    echo "  → Use 'kdse audit' for assessment details"
    echo "  → Use 'kdse status' to check repository health"
    
    # Phase 7: Complete
    print_step "7/7" "Complete - Session summary..."
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    echo "  KDSE Session Complete"
    echo "═══════════════════════════════════════════════════════════════"
    echo ""
    echo " Next Steps:"
    echo "   • Review the assessment report"
    echo "   • Address high-priority findings"
    echo "   • Run 'kdse run' again after implementing fixes"
    echo ""
}

assess_repository() {
    echo ""
    echo "─────────────────────────────────────────────────────────────"
    echo " ASSESSMENT RESULTS"
    echo "─────────────────────────────────────────────────────────────"
    echo ""
    
    # Count files
    local total_files=$(find . -type f -name "*.go" | wc -l)
    local test_files=$(find . -type f -name "*_test.go" | wc -l)
    local docs=$(find docs -type f 2>/dev/null | wc -l)
    
    echo " Architecture:"
    echo "   • Go source files: $total_files"
    echo "   • Test files: $test_files"
    echo "   • Documentation files: $docs"
    
    # Check for KDSE dimensions
    echo ""
    echo " KDSE Dimensions:"
    
    if [ -d "docs/architecture" ]; then
        print_success "Architecture Artifacts"
    else
        print_error "Architecture Artifacts"
    fi
    
    if [ -d "docs/adrs" ]; then
        print_success "Authority Hierarchy"
    else
        print_warning "Authority Hierarchy (missing ADRs)"
    fi
    
    if [ -f ".github/workflows" ] || [ -d ".github/workflows" ]; then
        print_success "Governance (CI/CD)"
    else
        print_warning "Governance"
    fi
    
    if [ $test_files -gt 0 ]; then
        print_success "Implementation Artifacts"
    else
        print_error "Implementation Artifacts"
    fi
    
    if [ $docs -gt 5 ]; then
        print_success "Knowledge Artifacts"
    else
        print_warning "Knowledge Artifacts"
    fi
    
    if [ -d ".kdse/reports" ]; then
        print_success "Traceability"
    else
        print_warning "Traceability"
    fi
    
    # Run tests if available
    echo ""
    echo " Verification:"
    if command -v go &> /dev/null; then
        if go test ./... 2>&1 | grep -q "ok"; then
            print_success "Tests passing"
        else
            local failures=$(go test ./... 2>&1 | grep -c "FAIL" || echo "0")
            if [ "$failures" -gt 0 ]; then
                print_error "Tests failing ($failures failures)"
            else
                print_success "Tests passing"
            fi
        fi
    else
        print_warning "Go not available"
    fi
    
    # Set recommendation
    TOP_RECOMMENDATION="Improve Verification Practices"
    TOP_PRIORITY="High"
    TOP_IMPACT="+1.0 points to overall score"
}

generate_report() {
    echo ""
    echo "─────────────────────────────────────────────────────────────"
    echo " KDSE ASSESSMENT REPORT"
    echo "─────────────────────────────────────────────────────────"
    echo ""
    
    # Create reports directory
    mkdir -p .kdse/reports
    
    # Calculate status values
    local arch_status="❌"
    [ -d "docs/architecture" ] && arch_status="✅"
    
    local auth_status="❌"
    [ -d "docs/adrs" ] && auth_status="✅"
    
    local gov_status="❌"
    [ -d ".github/workflows" ] && gov_status="✅"
    
    local impl_status="❌"
    [ $(find . -type f -name "*_test.go" 2>/dev/null | wc -l) -gt 0 ] && impl_status="✅"
    
    local know_status="❌"
    [ $(find docs -type f 2>/dev/null | wc -l) -gt 5 ] && know_status="✅"
    
    local trace_status="❌"
    [ -d ".kdse/reports" ] && trace_status="✅"
    
    local report_file=".kdse/reports/KDSE-RUN-$(date +%Y%m%d-%H%M%S).md"
    
    cat > "$report_file" << EOF
# KDSE Run Report

**Date:** $(date -Iseconds)  
**Repository:** $(basename $(pwd))  
**Session:** KDSE-RUN-$(date +%Y%m%d-%H%M%S)

---

## Summary

| Dimension | Status | Notes |
|-----------|--------|-------|
| Architecture Artifacts | $arch_status | |
| Authority Hierarchy | $auth_status | |
| Governance | $gov_status | CI/CD |
| Implementation Artifacts | $impl_status | |
| Knowledge Artifacts | $know_status | |
| Traceability | $trace_status | |
| Verification | ⚠️ | Tests need verification |

---

## Top Recommendation

**Action:** Improve Verification Practices

**Priority:** High

**Rationale:** This dimension has the lowest score and represents the highest-value improvement opportunity.

---

## Next Steps

1. Review failing tests (if any)
2. Address high-priority findings
3. Run 'kdse run' again after implementing fixes

---

*Generated by KDSE Runtime*
EOF
    
    print_success "Report saved to: $report_file"
}

