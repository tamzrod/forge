#===============================================================================
# Audit Helper Functions
#===============================================================================

# Check artifact existence
check_artifacts() {
    # Architecture
    has_context_diagram=$(find docs -name "*context*" 2>/dev/null | wc -l)
    has_component_diagram=$(find docs -name "*component*" 2>/dev/null | wc -l)
    has_sequence_diagram=$(find docs -name "*sequence*" 2>/dev/null | wc -l)
    has_api_docs=$(find docs -name "*api*" -o -name "*API*" 2>/dev/null | grep -v "Binary" | wc -l)
    has_deployment_docs=$(find docs -name "*deployment*" -o -name "*deploy*" 2>/dev/null | wc -l)
    
    # Governance
    has_issue_templates=$(find .github/issue_templates -type f 2>/dev/null | wc -l)
    has_pr_templates=$(find .github/pull_request_template* -type f 2>/dev/null | wc -l)
    has_lint_config=$(find . -name ".golangci.yml" -o -name ".golangci.yaml" 2>/dev/null | wc -l)
    has_readme_quality=$(grep -l "Quick Start\|Installation\|Usage" README.md 2>/dev/null | wc -l)
    has_changelog=$(find . -name "CHANGELOG*" -o -name "CHANGES*" 2>/dev/null | wc -l)
    
    # Files
    test_files=$(find . -type f -name "*_test.go" 2>/dev/null | wc -l)
    go_files=$(find . -type f -name "*.go" 2>/dev/null | wc -l)
    docs=$(find docs -type f 2>/dev/null | wc -l)
    adrs=$(find docs/adrs -type f -name "ADR-*.md" 2>/dev/null | wc -l)
    
    # Knowledge
    has_vision=$(find docs -name "vision.md" 2>/dev/null | wc -l)
    has_glossary=$(find docs -name "GLOSSARY.md" -o -name "glossary.md" 2>/dev/null | wc -l)
    
    # Verification
    has_ci=$(find .github/workflows -name "*.yml" -o -name "*.yaml" 2>/dev/null | wc -l)
    has_test_coverage=$(grep -c "coverage" .github/workflows/*.yml 2>/dev/null || echo "0")
    
    # Traceability
    has_trace_matrix=$(find docs -name "*trace*" -o -name "*Trace*" 2>/dev/null | wc -l)
}

# Print progress header
print_phase() {
    local phase="$1"
    local completed="$2"
    local current="$3"
    local next="$4"
    
    echo ""
    echo "═══════════════════════════════════════════════════════════════════════════"
    echo "  Current Phase"
    echo "  $phase"
    echo "═══════════════════════════════════════════════════════════════════════════"
    echo ""
    
    if [ -n "$completed" ]; then
        echo "  Completed"
        echo "  $completed" | sed 's/^/  /'
        echo ""
    fi
    
    if [ -n "$current" ]; then
        echo "  Current Task"
        echo "  Creating ${current}..."
        echo ""
    fi
    
    if [ -n "$next" ]; then
        echo "  Next"
        echo "  $next"
        echo ""
    fi
}

# Print completion message
print_completion() {
    local score="$1"
    local artifacts="$2"
    
    echo ""
    echo "═══════════════════════════════════════════════════════════════════════════"
    echo "  BUILD COMPLETE"
    echo "═══════════════════════════════════════════════════════════════════════════"
    echo ""
    echo "  Final Score: $score/10"
    echo "  Artifacts: $artifacts"
    echo ""
    echo "  All REQUIRED artifacts have been generated."
    echo ""
}

#===============================================================================
# Command: generate (Build Pipeline Mode)
#===============================================================================

cmd_generate() {
    print_header "KDSE Generate"
    echo "Building required artifacts automatically..."
    echo ""
    
    local loop=1
    local max_loops=20
    
    while [ $loop -le $max_loops ]; do
        check_artifacts
        
        # Track what we'll complete this run
        local completed=""
        local current=""
        local next=""
        local did_work=false
        
        # Architecture Phase
        echo ""
        echo "┌─────────────────────────────────────────────────────────────────────┐"
        echo "│ Phase 1: Architecture Readiness                                       │"
        echo "└─────────────────────────────────────────────────────────────────────┘"
        echo ""
        
        if [ $has_context_diagram -gt 0 ] && [ $has_component_diagram -gt 0 ] && [ $has_sequence_diagram -gt 0 ]; then
            echo "  ✓ Context Diagram (exists)"
            echo "  ✓ Component Diagram (exists)"
            echo "  ✓ Runtime Sequence Diagram (exists)"
            completed="${completed}✓ Context Diagram\n✓ Component Diagram\n✓ Runtime Sequence Diagram"
        else
            # Context Diagram
            if [ $has_context_diagram -eq 0 ]; then
                echo "  ✗ Context Diagram (missing)"
                if [ -z "$current" ]; then
                    current="Context Diagram"
                    cmd_generate_context
                    did_work=true
                    completed="${completed}✓ Context Diagram"
                fi
            else
                completed="${completed}✓ Context Diagram"
            fi
            
            # Component Diagram
            if [ $has_component_diagram -eq 0 ]; then
                echo "  ✗ Component Diagram (missing)"
                if [ -z "$current" ] && [ "$did_work" = false ]; then
                    current="Component Diagram"
                    cmd_generate_component
                    did_work=true
                    completed="${completed}\n✓ Component Diagram"
                fi
            else
                completed="${completed}\n✓ Component Diagram"
            fi
            
            # Sequence Diagram
            if [ $has_sequence_diagram -eq 0 ]; then
                echo "  ✗ Runtime Sequence Diagram (missing)"
                if [ -z "$current" ] && [ "$did_work" = false ]; then
                    current="Runtime Sequence Diagram"
                    cmd_generate_sequence
                    did_work=true
                    completed="${completed}\n✓ Runtime Sequence Diagram"
                fi
            else
                completed="${completed}\n✓ Runtime Sequence Diagram"
            fi
        fi
        
        echo ""
        echo "┌─────────────────────────────────────────────────────────────────────┐"
        echo "│ Phase 2: Governance Setup                                            │"
        echo "└─────────────────────────────────────────────────────────────────────┘"
        echo ""
        
        if [ $has_issue_templates -gt 0 ] && [ $has_pr_templates -gt 0 ] && [ $has_lint_config -gt 0 ]; then
            echo "  ✓ Issue Templates (exists)"
            echo "  ✓ PR Template (exists)"
            echo "  ✓ Linting Configuration (exists)"
        else
            # Issue Templates
            if [ $has_issue_templates -eq 0 ]; then
                echo "  ✗ Issue Templates (missing)"
                if [ -z "$current" ]; then
                    current="Issue Templates"
                    cmd_generate_issue_templates
                    did_work=true
                fi
            fi
            
            # PR Template
            if [ $has_pr_templates -eq 0 ]; then
                echo "  ✗ PR Template (missing)"
                if [ -z "$current" ]; then
                    current="PR Template"
                    cmd_generate_pr_template
                    did_work=true
                fi
            fi
            
            # Lint Config
            if [ $has_lint_config -eq 0 ]; then
                echo "  ✗ Linting Configuration (missing)"
                if [ -z "$current" ]; then
                    current="Linting Configuration"
                    cmd_generate_lint_config
                    did_work=true
                fi
            fi
        fi
        
        echo ""
        echo "┌─────────────────────────────────────────────────────────────────────┐"
        echo "│ Phase 3: Knowledge Base                                              │"
        echo "└─────────────────────────────────────────────────────────────────────┘"
        echo ""
        
        if [ $has_vision -gt 0 ] && [ $has_glossary -gt 0 ]; then
            echo "  ✓ Vision Document (exists)"
            echo "  ✓ Glossary (exists)"
        else
            # Vision Document
            if [ $has_vision -eq 0 ]; then
                echo "  ✗ Vision Document (missing)"
                if [ -z "$current" ]; then
                    current="Vision Document"
                    cmd_generate_vision
                    did_work=true
                fi
            fi
            
            # Glossary
            if [ $has_glossary -eq 0 ]; then
                echo "  ✗ Glossary (missing)"
                if [ -z "$current" ]; then
                    current="Glossary"
                    cmd_generate_glossary
                    did_work=true
                fi
            fi
        fi
        
        # Check if all required artifacts are complete
        check_artifacts
        
        local all_complete=true
        [ $has_context_diagram -eq 0 ] && all_complete=false
        [ $has_component_diagram -eq 0 ] && all_complete=false
        [ $has_sequence_diagram -eq 0 ] && all_complete=false
        [ $has_issue_templates -eq 0 ] && all_complete=false
        [ $has_pr_templates -eq 0 ] && all_complete=false
        [ $has_lint_config -eq 0 ] && all_complete=false
        [ $has_vision -eq 0 ] && all_complete=false
        [ $has_glossary -eq 0 ] && all_complete=false
        
        if [ "$all_complete" = true ]; then
            # Calculate score
            local total=$((6 + 7 + 7 + 6 + 6 + 4 + 4))
            local overall=$(awk "BEGIN {printf \"%.1f\", ($total/70)*10}")
            
            print_completion "$overall" "$docs docs | $(find .github -type f 2>/dev/null | wc -l) github files"
            break
        fi
        
        # If no work was done this iteration but we're not complete, something is wrong
        if [ "$did_work" = false ]; then
            echo ""
            echo "  ⚠ Some artifacts couldn't be auto-generated."
            echo "  Run './kdse audit' for manual recommendations."
            break
        fi
        
        ((loop++))
    done
}

