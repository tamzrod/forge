    echo "Runtime:"
    echo "  Version: 1.0.0"
    echo "  Repository: $KDSE_REPO"
    echo "  Branch: $KDSE_BRANCH"
    echo ""
    
    echo "Local Installation:"
    if [ -d ".kdse" ]; then
        print_success ".kdse directory exists"
    else
        print_error ".kdse directory not found"
    fi
    
    if [ -f ".kdse/knowledge/manifest.yaml" ]; then
